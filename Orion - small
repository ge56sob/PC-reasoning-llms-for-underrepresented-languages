def extract_answer(text):
    """Upgraded parser that finds numbers even if the model ignores the format."""
    if not text or "Generation Error" in text:
        return "NO_BOXED_ANSWER"
        
    # STAGE 1: Try to find standard LaTeX boxes: \boxed{18}
    boxed_match = re.search(r'\\boxed\{([^}]+)\}', text)
    if boxed_match:
        return boxed_match.group(1).strip()
    
    # STAGE 2: Look for conversational text markers like "là 18" or "is 18"
    marker_match = re.search(r'(?:Đáp án|Answer|kết quả là|is|=>)\s*\**([0-9\.,]+)', text, re.IGNORECASE)
    if marker_match:
        return marker_match.group(1).strip()
        
    # STAGE 3: THE ULTIMATE FALLBACK (Grab the absolute last number)
    all_numbers = re.findall(r'[0-9\.,]+', text)
    if all_numbers:
        return all_numbers[-1].strip() 
        
    return "NO_BOXED_ANSWER"


