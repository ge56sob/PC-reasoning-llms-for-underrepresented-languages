# Load Dataset

from datasets import load_dataset

print("Loading datasets...")

ds_vi = load_dataset("Qwen/PolyMath", "vi")
ds_en = load_dataset("Qwen/PolyMath", "en")

print("Dataset loaded successfully!")
print(f"Available levels: {list(ds_vi.keys())}")


# Initialize Pipeline

import torch
from transformers import pipeline

model_name = "Enter  Pytorch model here"

print(f"Loading {model_name} onto the GPU...")

pipe = pipeline(
    "text-generation",
    model=model_name,
    torch_dtype=torch.bfloat16,   # Optimized precision for Next-1B
    device_map="auto",
    model_kwargs={"attn_implementation": "eager"}
)

# Quick sanity check
messages = [{"role": "user", "content": "Who are you?"}]
test_output = pipe(messages, max_new_tokens=50)

print("\n--- Sanity Check Output ---")
print(test_output[0]["generated_text"][-1]["content"])
print("---------------------------\n")


# Helper Functions

import re

def extract_answer(text):
    """Extract numeric answers from reasoning models, including boxed LaTeX."""
    
    if not text or "Generation Error" in text:
        return "NO_BOXED_ANSWER"

    # Remove <think> block
    if "</think>" in text:
        clean_target_text = text.split("</think>")[-1].strip()
    else:
        clean_target_text = text.strip()

    # Stage 1: LaTeX boxed answers
    boxed_match = re.search(r'\\boxed\{(.*?)\}', clean_target_text)
    if boxed_match:
        content = boxed_match.group(1)
        if content.endswith('}') and content.count('{') == content.count('}') - 1:
            content = content[:-1]
        return content.strip()

    # Stage 2: Conversational markers
    marker_match = re.search(
        r'(?:Đáp án|Answer|kết quả là|is|=>)\s*\**(\-?[0-9\.,/]+)',
        clean_target_text,
        re.IGNORECASE
    )
    if marker_match:
        return marker_match.group(1).strip()

    # Stage 3: Fallback numeric extraction
    all_numbers = re.findall(r'\-?[0-9]+[\.,]?[0-9]*|\-?[0-9]+', clean_target_text)
    if all_numbers:
        return all_numbers[-1].strip()

    return "NO_BOXED_ANSWER"


def detect_reasoning_language(text):
    """Detect reasoning language inside <think> tags."""
    
    if not text:
        return "UNKNOWN"

    think_match = re.search(r'<think>(.*?)</think>', text, re.DOTALL)
    content = think_match.group(1) if think_match else text

    vn_chars = re.compile(
        r'[àáạảãâầấậẩẫăằắặẳẵèéẹẻẽêềếệểễìíịỉĩ'
        r'òóọỏõôồốộổỗơờớợởỡùúụủũưừứựửữỳýỵỷỹđ]',
        re.IGNORECASE
    )

    vn_count = len(vn_chars.findall(content[:1000]))

    return "VIETNAMESE" if vn_count > 1 else "ENGLISH"


languages_to_test = [
    {"name": "VIETNAMESE", "dataset": ds_vi},
    {"name": "ENGLISH", "dataset": ds_en}
]


# Global Accuracy Trackers

global_total = 0
global_correct = 0

global_level_stats = {
    "MEDIUM": {"total": 0, "correct": 0, "en_reasoning": 0, "vi_reasoning": 0},
    "LOW":    {"total": 0, "correct": 0, "en_reasoning": 0, "vi_reasoning": 0}
}


# Benchmark Execution Loop

for lang in languages_to_test:

    print("\n" + "=" * 80)
    print(f" RUNNING {lang['name']} BENCHMARK TRACK ")
    print("=" * 80 + "\n")

    current_ds = lang["dataset"]

    for level in current_ds.keys():

        level_upper = level.upper()

        if level_upper not in ["MEDIUM", "LOW"]:
            continue

        print(f"\n LEVEL SIFTING: {level_upper}")
        print("-" * 50)

        dataset = current_ds[level]

        level_correct = 0
        level_total = len(dataset)
        actual_level_total = 0

        level_english_count = 0
        level_vietnamese_count = 0

        for i in range(level_total):

            row = dataset[i]
            current_id = row.get("id", f"{level}-{i}")

            global_total += 1
            actual_level_total += 1
            global_level_stats[level_upper]["total"] += 1

            print(f"\n[Q {global_total}] ID: {current_id}")
            print(f"Question: {row['question']}\n")

            messages = [{"role": "user", "content": row["question"]}]

            try:
                outputs = pipe(
                    messages,
                    max_new_tokens=2000,
                    temperature=0.0,
                    do_sample=False
                )
                model_response = outputs[0]["generated_text"][-1]["content"]

            except Exception as e:
                model_response = f"Generation Error: {e}"
                print(f" Execution Error: {e}")

            print("--- MODEL RESPONSE BLOCK ---")
            print(model_response)
            print("----------------------------\n")

            reasoning_lang = detect_reasoning_language(model_response)

            if reasoning_lang == "ENGLISH":
                level_english_count += 1
                global_level_stats[level_upper]["en_reasoning"] += 1
            elif reasoning_lang == "VIETNAMESE":
                level_vietnamese_count += 1
                global_level_stats[level_upper]["vi_reasoning"] += 1

            extracted = extract_answer(model_response)
            ground_truth = str(row["answer"]).strip()

            if extracted == ground_truth:
                is_correct = "✅"
                level_correct += 1
                global_correct += 1
                global_level_stats[level_upper]["correct"] += 1
            else:
                is_correct = "❌"

            print(f" Extracted: '{extracted}'")
            print(f" Target Truth: '{ground_truth}'")
            print(f"Result: {is_correct} | Reasoning Lang: {reasoning_lang}")
            print("=" * 60)

        if actual_level_total > 0:
            level_accuracy = (level_correct / actual_level_total) * 100

            print(f"\n SECTION SUMMARY [{lang['name']} - {level_upper}]:")
            print(f"Correct: {level_correct}/{actual_level_total}")
            print(f"Accuracy: {level_accuracy:.2f}%")
            print(f"Reasoning breakdown: {level_english_count} English, {level_vietnamese_count} Vietnamese")
            print("-" * 60 + "\n")


# Final Accuracy Report

print("\n" + "█" * 80)
print(" FINAL BENCHMARK PERFORMANCE REPORT ")
print("█" * 80)

if global_total > 0:

    final_accuracy = (global_correct / global_total) * 100

    print(f" Total Questions : {global_total}")
    print(f" Total Correct   : {global_correct}")
    print(f" Overall Accuracy: {final_accuracy:.2f}%")
    print("=" * 60)

    for lvl in ["MEDIUM", "LOW"]:
        stats = global_level_stats[lvl]
        if stats["total"] > 0:
            acc = (stats["correct"] / stats["total"]) * 100
            print(f"[{lvl}] Accuracy : {acc:.2f}% ({stats['correct']}/{stats['total']})")
            print(f"[{lvl}] Reasoned English : {stats['en_reasoning']}")
            print(f"[{lvl}] Reasoned Viet    : {stats['vi_reasoning']}")
            print("-" * 40)

else:
    print("No benchmark data was evaluated.")

print("█" * 80 + "\n")
