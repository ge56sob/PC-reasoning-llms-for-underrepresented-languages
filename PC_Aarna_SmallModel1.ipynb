        "<a href=\"https://colab.research.google.com/github/ge56sob/PC-reasoning-llms-for-underrepresented-languages/blob/main/PC_Aarna_SmallModel1.ipynb\" target=\"_parent\"><img src=\"https://colab.research.google.com/assets/colab-badge.svg\" alt=\"Open In Colab\"/></a>"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "import re\n",
        "import torch\n",
        "from datasets import load_dataset\n",
        "from transformers import AutoTokenizer, AutoModelForCausalLM\n",
        "\n",
        "MODEL_ID = \"tencent/HY-MT1.5-1.8B\"\n",
        "LANGUAGES = [\"en\", \"vi\"]\n",
        "SPLITS = [\"low\", \"medium\", \"high\", \"top\"]\n",
        "MAX_EXAMPLES_PER_SPLIT = 20  # increase later, e.g. 125 for full split\n",
        "\n",
        "def normalize_answer(text):\n",
        "    text = str(text).strip().lower()\n",
        "    text = re.sub(r\"\\s+\", \"\", text)\n",
        "    text = text.replace(\"$\", \"\")\n",
        "    text = text.replace(\"\\\\left\", \"\").replace(\"\\\\right\", \"\")\n",
        "    return text\n",
        "\n",
        "POLYMATH_INSTRUCTIONS = {\n",
        "    \"en\": r\"Note: Please put the final answer in the $\\boxed{}$.\",\n",
        "    \"vi\": r\"Lưu ý: Vui lòng đặt câu trả lời cuối cùng trong $\\boxed{}$.\",\n",
        "}\n",
        "\n",
        "def build_prompt(question, lang):\n",
        "    return f\"{question}\\n\\n{POLYMATH_INSTRUCTIONS[lang]}\"\n",
        "\n",
        "\n",
        "def generate_answer(question, tokenizer, model):\n",
        "    prompt = build_prompt(question, lang)\n",
        "\n",
        "    messages = [{\"role\": \"user\", \"content\": prompt}]\n",
        "\n",
        "    if getattr(tokenizer, \"chat_template\", None):\n",
        "        inputs = tokenizer.apply_chat_template(\n",
        "            messages,\n",
        "            add_generation_prompt=True,\n",
        "            tokenize=True,\n",
        "            return_dict=True,\n",
        "            return_tensors=\"pt\",\n",
        "        ).to(model.device)\n",
        "    else:\n",
        "        inputs = tokenizer(\n",
        "            prompt,\n",
        "            return_tensors=\"pt\",\n",
        "        ).to(model.device)\n",
        "\n",
        "    with torch.no_grad():\n",
        "        outputs = model.generate(\n",
        "            **inputs,\n",
        "            max_new_tokens=64,\n",
        "            do_sample=False,\n",
        "            temperature=None,\n",
        "            pad_token_id=tokenizer.eos_token_id,\n",
        "        )\n",
        "\n",
        "    response = tokenizer.decode(\n",
        "        outputs[0][inputs[\"input_ids\"].shape[-1]:],\n",
        "        skip_special_tokens=True,\n",
        "    ).strip()\n",
        "\n",
        "    return response\n",
        "\n",
        "print(\"Loading model...\")\n",
        "tokenizer = AutoTokenizer.from_pretrained(MODEL_ID, trust_remote_code=True)\n",
        "model = AutoModelForCausalLM.from_pretrained(\n",
        "    MODEL_ID,\n",
        "    torch_dtype=torch.float16 if torch.cuda.is_available() else torch.float32,\n",
        "    device_map=\"auto\",\n",
        "    trust_remote_code=True,\n",
        ")\n",
        "model.eval()\n",
        "\n",
        "all_results = []\n",
        "\n",
        "for lang in LANGUAGES:\n",
        "    for split in SPLITS:\n",
        "        print(f\"\\nTesting language={lang}, split={split}\")\n",
        "\n",
        "        dataset = load_dataset(\"Qwen/PolyMath\", lang, split=split)\n",
        "\n",
        "        correct = 0\n",
        "        total = min(MAX_EXAMPLES_PER_SPLIT, len(dataset))\n",
        "\n",
        "        for i, row in enumerate(dataset.select(range(total))):\n",
        "            question = row[\"question\"]\n",
        "            gold_answer = row[\"answer\"]\n",
        "\n",
        "            model_answer = generate_answer(question, tokenizer, model)\n",
        "\n",
        "            is_correct = (\n",
        "                normalize_answer(model_answer)\n",
        "                == normalize_answer(gold_answer)\n",
        "            )\n",
        "\n",
        "            correct += int(is_correct)\n",
        "\n",
        "            result = {\n",
        "                \"language\": lang,\n",
        "                \"split\": split,\n",
        "                \"id\": row.get(\"id\", str(i)),\n",
        "                \"question\": question,\n",
        "                \"gold_answer\": gold_answer,\n",
        "                \"model_answer\": model_answer,\n",
        "                \"correct\": is_correct,\n",
        "            }\n",
        "            all_results.append(result)\n",
        "\n",
        "            print(f\"{i + 1}/{total} correct={is_correct}\")\n",
        "\n",
        "        accuracy = correct / total if total else 0\n",
        "        print(f\"Accuracy for {lang}/{split}: {accuracy:.3f}\")\n",
        "\n",
        "output_file = \"polymath_results_HY-MT1.5-1.8B.txt\"\n",
        "\n",
        "with open(output_file, \"w\", encoding=\"utf-8\") as f:\n",
        "    for r in all_results:\n",
        "        f.write(\"=\" * 80 + \"\\n\")\n",
        "        f.write(f\"Model: {MODEL_ID}\\n\")\n",
        "        f.write(f\"Language: {r['language']}\\n\")\n",
        "        f.write(f\"Split: {r['split']}\\n\")\n",
        "        f.write(f\"ID: {r['id']}\\n\")\n",
        "        f.write(f\"Correct: {r['correct']}\\n\\n\")\n",
        "        f.write(\"Question:\\n\")\n",
        "        f.write(r[\"question\"] + \"\\n\\n\")\n",
        "        f.write(\"PolyMath answer:\\n\")\n",
        "        f.write(str(r[\"gold_answer\"]) + \"\\n\\n\")\n",
        "        f.write(\"Model answer:\\n\")\n",
        "        f.write(str(r[\"model_answer\"]) + \"\\n\\n\")\n",
        "\n",
        "print(f\"\\nSaved results to {output_file}\")"
      ],
